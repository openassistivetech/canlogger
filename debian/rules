#!/usr/bin/make -f
# Single-line "let debhelper do everything sensible" recipe.
%:
	dh $@

# Per-unit systemd enable control:
#   - canlogger.service: enable AND start on install (the capture pipeline)
#   - canlog-upload.service + canlog-upload.timer: install only; admin enables
#     manually once rclone has been configured with a remote.
override_dh_installsystemd:
	dh_installsystemd --name=canlogger
	dh_installsystemd --name=canlog-upload --no-enable --no-start

# Generate the man pages from markdown at build time. Keeping the source in
# markdown means the docs are editable the same way as the README; pandoc
# emits roff that man(1) reads. debhelper's dh_installman auto-installs
# *.7/*.1 from the build tree into /usr/share/man/man7//man1/. The two *.1
# pages exist only so lintian's no-manual-page check is satisfied for each
# installed binary; they just point at canlogger(7) and the README.
override_dh_auto_build:
	pandoc --standalone --to man canlogger.7.md -o canlogger.7
	pandoc --standalone --to man canlog-rotate.1.md -o canlog-rotate.1
	pandoc --standalone --to man canlog-upload.1.md -o canlog-upload.1
	# Pandoc's --standalone man output includes a 14-line preamble that tests
	# for the CB (Courier Bold) groff font at runtime using:
	#   .ie "\f[CB]x\f[]"x" \{...\}
	#   .el \{...\}
	# The test itself causes troff to warn "cannot select font 'CB'", and
	# code blocks in the body use \f[C] which triggers "cannot select font
	# 'C'".  Both warnings make lintian fail.  Strip the preamble with awk
	# (skip from the ".\" Define V font" comment through the two .\} closers)
	# and replace Courier/virtual-Courier font refs in the body with \f[B]
	# (Bold), which is the fallback the preamble would have chosen anyway.
	for f in canlogger.7 canlog-rotate.1 canlog-upload.1; do \
		awk '/^\.\\" Define V font/{s=2;next} s>0{if(/^\.\\\}/)s--;next} 1' "$$f" > "$$f.tmp" && mv "$$f.tmp" "$$f"; \
		sed -i 's/\\f\[C[BI]\{0,2\}\]/\\f[B]/g; s/\\f\[V[BI]\{0,2\}\]/\\f[B]/g' "$$f"; \
	done
	dh_auto_build

override_dh_auto_clean:
	rm -f canlogger.7 canlog-rotate.1 canlog-upload.1
	dh_auto_clean

# Leave /usr/share/doc/canlogger/README.md uncompressed. It's small (~18 KB)
# and users read it directly; gzipping just forces zless/zcat every time.
# Man pages under /usr/share/man/ are still compressed by dh_compress normally.
override_dh_compress:
	dh_compress -X README.md
